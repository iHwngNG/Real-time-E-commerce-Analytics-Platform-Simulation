# =============================================================================
# Real-time E-commerce Analytics Platform — Environment Variables
# =============================================================================
# Copy file này thành .env trước khi chạy:
#   cp .env.example .env
# =============================================================================

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=ecommerce

# ─── Redis ───────────────────────────────────────────────────────────────────
# (không cần password trong dev, bỏ trống)
REDIS_PASSWORD=

# ─── Airflow ─────────────────────────────────────────────────────────────────
# Tạo Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=UKMzEm3yIuFYEq1y3-2FxPNWSVwRASpahmQ9z6xRFkA=
AIRFLOW_SECRET_KEY=ecommerce-analytics-secret
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin123

# ─── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# ─── Simulator (F1) ──────────────────────────────────────────────────────────
NUM_USERS=10000
NUM_PRODUCTS=5000
NUM_ACTIVE_USERS=100
TARGET_EVENTS_PER_SEC=500
PEAK_HOUR_ENABLED=true

# ─── Logging ─────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
